@model List<TP_04.Models.Figurita>

<h1>Figuritas Repetidas</h1>

@if(Model.Count == 0)
{
    <p>No hay figuritas repetidas.</p>
}
else
{
    <table border="1">

    <tr>

        <th>Nombre</th>

        <th>Tipo</th>

    </tr>

    @foreach(var f in Model)
    {
        <tr>

            <td>@f.Nombre</td>

            <td>@f.Tipo</td>

        </tr>
    }

    </table>
}

<br>

<a href='@Url.Action("Index","Home")'>Volver</a>